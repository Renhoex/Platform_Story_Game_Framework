; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Platform Story Game Framework"
run/main_scene="uid://clva3c4fsuapy"
config/features=PackedStringArray("4.6", "Forward Plus")
boot_splash/stretch_mode=2
boot_splash/image="uid://dm3s18gsa3g6m"
config/icon="uid://biihnl5dx266b"

[autoload]

GlobalAudio="*res://global/audio/global_audio.tscn"
GlobalOverlay="*res://global/layers/global_overlay.tscn"
GlobalMusic="*res://global/audio/global_music.tscn"
Global="*uid://dcn8i80grfwif"
Dialogic="*uid://ds2q0uclmolvu"
PauseMenu="*uid://66c55m6xxk3e"
GlobalWeapons="*uid://c4o1piswol38j"
DialogicFunctions="*uid://kss78qobxq61"
GlobalHud="*uid://5b0rfccsv14q"
GlobalItems="*uid://vvge711y3dmw"
Progress="*uid://dann0ydyp3ls"

[dialogic]

directories/dch_directory={
"guy": "res://dialogic/characters/guy.dch",
"radio": "res://dialogic/characters/radio.dch"
}
directories/dtl_directory={
"armory_dialogue": "res://dialogic/timelines/armory_dialogue.dtl",
"boss_beat": "res://dialogic/timelines/boss_beat.dtl",
"boss_intro": "res://dialogic/timelines/boss_intro.dtl",
"fail_sign": "res://dialogic/timelines/fail_sign.dtl",
"game_over": "res://dialogic/general/game_over.dtl",
"get_upgrade": "res://dialogic/general/get_upgrade.dtl",
"open_chest": "res://dialogic/general/open_chest.dtl",
"refill_station": "res://dialogic/general/refill_station.dtl",
"save": "res://dialogic/general/save.dtl",
"sign": "res://dialogic/timelines/sign.dtl",
"test": "res://dialogic/timelines/test.dtl",
"zoo_door": "res://dialogic/timelines/zoo_door.dtl",
"zoo_key": "res://dialogic/item_descriptions/zoo_key.dtl"
}
layout/style_directory={
"": "res://dialogic/style.tres",
"style": "res://dialogic/style.tres"
}
variables={
"BOSS": {
"ball_boss_beat": false,
"boss_encountered": false
},
"CHESTS": {
"standard_gun": false
},
"EVENTS": {
"intro_played": false,
"talked_to_guy": false,
"zoo_door_unlocked": false
},
"ITEMS": {
"collected": false,
"is_weapon": true,
"item_id": "[UNDEFINED]",
"item_name": "[UNDEFINED]"
},
"TIMELINE": {
"next_timeline": ""
}
}
extensions_folder="res://addons/dialogic_additions"
text/letter_speed=0.01
text/initial_text_reveal_skippable=true
text/text_reveal_skip_delay=0.1
text/advance_delay=0.1
text/autoadvance_per_character_delay=0.1
text/autoadvance_ignored_characters_enabled=true
animations/join_default_length=0.5
animations/join_default_wait=false
animations/leave_default_length=0.5
animations/leave_default_wait=false
animations/cross_fade_default_length=0.5
choices/autofocus_first=true
choices/delay=0.2
choices/reveal_delay=0
choices/reveal_by_input=false
save/autosave_delay=60.0
save/encryption_on_exports_only=true
text/autopauses={}
audio/channel_defaults={
"": {
"audio_bus": "SFX",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
},
"music": {
"audio_bus": "Music",
"fade_length": 0.0,
"loop": true,
"volume": 0.0
},
"music-one-shot": {
"audio_bus": "Music",
"fade_length": 0.0,
"loop": false,
"volume": 0.0
}
}
layout/style_list=["res://dialogic/style.tres"]
layout/default_style="res://dialogic/style.tres"
glossary/default_case_sensitive=true
animations/join_default="Instant In"
animations/leave_default="Instant Out"
animations/cross_fade_default="Fade Cross"
portraits/default_portrait=""
text/input_action="gm_jump"
choices/hotkey_behaviour=0

[display]

window/size/viewport_width=320
window/size/viewport_height=240
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogic/plugin.cfg")

[file_customization]

folder_colors={
"res://audio/": "blue",
"res://audio/music/": "teal",
"res://dialogic/": "teal",
"res://entity/": "red",
"res://global/": "yellow",
"res://graphics/": "green",
"res://scenes/": "purple",
"res://script/": "pink",
"res://script/sequence_components/": "orange",
"res://tileset/": "gray"
}

